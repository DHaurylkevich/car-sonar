6. ОБРАБОТЧИКИ (все bot.action и bot.on)
┌────────────────────────┬─────────────────────┬─────────────────────────────────┐
│ Action / Command       │ Handler             │ Назначение                      │
├────────────────────────┼─────────────────────┼─────────────────────────────────┤
│ /start, /menu, "menu"  │ menuHandler.js      │ Главное меню                    │
│ "/stop"                │ menuHandler.js      │ Сброс бота                      │
│ "stop_bot"             │ menuHandler.js      │ Сброс через callback            │
│ "get_premium"          │ menuHandler.js      │ Заглушка "in progress"          │
│ "filterGroup"          │ groupSectionHandler │ Список групп фильтров           │
│                        │ .js                 │                                 │
│ "create_group"         │ groupSectionHandler │ Меню выбора типов фильтров      │
│                        │ .js                 │                                 │
│ "save"                 │ groupSectionHandler │ Сохранение группы в БД          │
│                        │ .js                 │                                 │
│ show_group_(\d+)       │ groupSectionHandler │ Просмотр фильтров группы        │
│                        │ .js                 │                                 │
│ edit_group_(\d+)       │ groupSectionHandler │ Редактирование группы           │
│                        │ .js                 │                                 │
│ delete_group_(\d+)     │ groupSectionHandler │ Удаление группы                 │
│                        │ .js                 │                                 │
│ filters_(\w+)          │ filterHandler.js    │ Список значений конкретного     │
│                        │                     │ фильтра                         │
│ set_(\d+)              │ filterHandler.js    │ Выбор/отмена значения (toggle)  │
│ reset                  │ filterHandler.js    │ Сброс выбранного фильтра        │
│ prev_(\w+) /           │ moveButtonHandler.j │ Пагинация списка                │
│ next_(\w+)             │ s                   │                                 │
│ bot.on("text")         │ filterHandler.js    │ Ручной ввод                     │
│                        │                     │ (Year/Mileage/Price)            │
└────────────────────────┴─────────────────────┴─────────────────────────────────┘
────────────────────────────────────────────────────────────────────────────────
